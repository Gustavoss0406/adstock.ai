{"trigger_id":"on_approval_needed","event":"approval_needed","payload_required":["agent_id","content_type"],"actions":[{"agent_id":"{{agent_id}}","state":"waiting","animation":"sit_look_screen","speech_bubble":"Aguardando CEO..."}]}
